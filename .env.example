# Переименуйте этот файл в .env и вставьте свой токен от @BotFather
BOT_TOKEN=123456789:AAExampleTokenReplaceWithYourOwn

# Необязательно: если бот не может подключиться к api.telegram.org напрямую
# (провайдер блокирует/режет), укажите адрес прокси или локального VPN-клиента.
# Раскомментируйте и впишите свой прокси:
# PROXY_URL=socks5://127.0.0.1:1080
# PROXY_URL=http://127.0.0.1:8080
